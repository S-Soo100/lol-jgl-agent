# === Riot API ===
# 개발용 키 (https://developer.riotgames.com, 24시간마다 갱신)
RIOT_API_KEY=RGAPI-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# 기본 소환사 (Riot ID: 이름#태그) — CLI에서 --riot-id 미지정 시 사용
DEFAULT_RIOT_ID=이름#KR1

# 지역: platform=소환사/스펙테이터, region=매치/타임라인 라우팅
RIOT_PLATFORM=kr
RIOT_REGION=asia

# === 조언(LLM) 백엔드 ===
# subscription = 구독 Claude(claude CLI, claude -p) 사용  ← MVP 기본
# api          = anthropic API 키 사용 (배포용)
ADVISOR_BACKEND=subscription

# claude CLI가 PATH에 없을 때만 실행 파일 경로 지정
# CLAUDE_CLI_PATH=C:\Users\deerm\AppData\Local\...\claude.exe

# api 백엔드 사용 시에만 필요
# ANTHROPIC_API_KEY=sk-ant-...
